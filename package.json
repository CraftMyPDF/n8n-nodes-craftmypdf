{
	"name": "n8n-nodes-craftmypdf",
	"version": "0.2.1",
	"description": "Automating PDF Document Creation has never been easier with CraftMyPDF's PDF template editor and PDF generation API!",
	"keywords": [
		"n8n-community-node-package"
	],
	"license": "MIT",
	"homepage": "https://craftmypdf.com/",
	"bugs": {
		"url": "https://github.com/CraftMyPDF/n8n-nodes-craftmypdf/issues",
		"email": "hello@craftmypdf.com"
	},
	"author": {
		"name": "CraftMyPDF",
		"email": "hello@craftmypdf.com"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/CraftMyPDF/n8n-nodes-craftmypdf.git"
	},
	"engines": {
		"node": ">=24.14",
		"pnpm": ">=11.9.0"
	},
	"scripts": {
		"build": "n8n-node build",
		"build:watch": "tsc --watch",
		"dev": "n8n-node dev",
		"prettier": "prettier --check .",
		"prettier:fix": "prettier --write .",
		"lint": "n8n-node lint",
		"lint:fix": "n8n-node lint --fix",
		"release": "n8n-node release",
		"prepublishOnly": "n8n-node prerelease"
	},
	"files": [
		"dist"
	],
	"n8n": {
		"n8nNodesApiVersion": 1,
		"strict": true,
		"credentials": [
			"dist/credentials/CraftMyPdfApi.credentials.js"
		],
		"nodes": [
			"dist/nodes/CraftMyPdf/CraftMyPdf.node.js"
		]
	},
	"devDependencies": {
		"@n8n/node-cli": "0.23.0",
		"eslint": "9.32.0",
		"prettier": "3.8.1",
		"release-it": "19.2.4",
		"typescript": "5.9.3"
	},
	"peerDependencies": {
		"n8n-workflow": "2.13.0"
	}
}
